{
  "expo": {
    "name": "IronBody",
    "slug": "ironbody",
    "version": "1.0.0",
    "scheme": "ironbody",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": { "image": "./assets/splash.png", "resizeMode": "contain", "backgroundColor": "#0a0a0a" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "app.ironbody" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#0a0a0a" }, "package": "app.ironbody" },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
