# Database (Supabase ou local Docker)
DATABASE_URL="postgresql://ironbody:ironbody_secret@localhost:5432/ironbody?schema=public"

# Auth
JWT_SECRET="sua-chave-secreta-longa-e-aleatoria"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (modo TEST) — webhook: POST /v1/stripe/webhook
STRIPE_SECRET_KEY=""
STRIPE_PUBLIC_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PERSONAL_PRICE_ID=""
STRIPE_ALUNO_PRICE_ID=""

# AWS S3 (sa-east-1)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=sa-east-1
AWS_S3_BUCKET_MEDIA=IronBody-media
AWS_S3_BUCKET_VIDEOS=IronBody-videos
AWS_S3_BUCKET_PHOTOS=IronBody-photos

# Agora
AGORA_APP_ID=""
AGORA_APP_CERTIFICATE=""

# SendGrid
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=noreply@ironbody.app
SENDGRID_FROM_NAME=IronBody

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-4.1-mini

# App
APP_URL_WEB=https://ironbody.app
APP_URL_API=https://api.ironbody.app
